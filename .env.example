# ============================================================================
# Messaging Platform — choose one: 'slack' or 'sms'
# ============================================================================
MESSAGING_PLATFORM=slack

# ============================================================================
# Slack (required if MESSAGING_PLATFORM=slack)
# ============================================================================
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ============================================================================
# SMS / WhatsApp via Twilio (required if MESSAGING_PLATFORM=sms)
# ============================================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_ALLOWED_NUMBER=+13129754202
# Set to 1 to use WhatsApp instead of SMS
TWILIO_USE_WHATSAPP=0

# ============================================================================
# Claude (Anthropic)
# ============================================================================
ANTHROPIC_API_KEY=...
# Optional: override model (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# ============================================================================
# GitHub
# ============================================================================
GITHUB_TOKEN=...

# ============================================================================
# Sandbox behavior
# ============================================================================
OPENCLAW_WORKDIR=/tmp/openclaw-jobs
OPENCLAW_RUN_TESTS=0
CI=1

# ============================================================================
# Brain (local-first memory with GCS backup)
# ============================================================================
OPENCLAW_BRAIN_DIR=/tmp/openclaw-brain
OPENCLAW_BRAIN_BUCKET=your-gcs-bucket-name
OPENCLAW_BRAIN_PREFIX=openclaw-brain

# ============================================================================
# Git commit identity (for sandbox PRs)
# ============================================================================
GIT_AUTHOR_EMAIL=openclaw@bot.local
GIT_AUTHOR_NAME=OpenClaw Bot

# ============================================================================
# Gmail (optional — OAuth2 credentials for email access)
# ============================================================================
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...
GMAIL_USER_EMAIL=you@gmail.com

# ============================================================================
# GCP (for GCS backup + Compute Engine)
# ============================================================================
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
# VM instance name used by deploy-gce.sh (default: openclaw-vm)
OPENCLAW_INSTANCE=openclaw-vm

# Alternative credential injection (optional):
# GCP_SA_KEY_B64=base64-of-service-account-json
