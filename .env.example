# ============================================================================
# Messaging Platform: 'telegram'
# ============================================================================
MESSAGING_PLATFORM=telegram

# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated list of allowed Telegram user IDs (leave empty to allow all)
TELEGRAM_ALLOWED_USER_IDS=
# Joining code — users must send this code before the bot responds (leave empty to disable)
TELEGRAM_JOIN_CODE=

# ============================================================================
# Claude (Anthropic)
# ============================================================================
ANTHROPIC_API_KEY=...
# Optional: override model (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# ============================================================================
# OpenAI (optional, if using LLM_PROVIDER=openai)
# ============================================================================
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-5
LLM_PROVIDER=anthropic

# ============================================================================
# GitHub
# ============================================================================
GITHUB_TOKEN=...

# ============================================================================
# Sandbox behavior
# ============================================================================
OPENCLAW_WORKDIR=/tmp/openclaw-jobs
OPENCLAW_RUN_TESTS=0
CI=1

# ============================================================================
# Brain (local-first memory with GCS backup)
# ============================================================================
OPENCLAW_BRAIN_DIR=/tmp/openclaw-brain
OPENCLAW_BRAIN_BUCKET=your-gcs-bucket-name
OPENCLAW_BRAIN_PREFIX=openclaw-brain

# ============================================================================
# Repos to index (optional, comma-separated)
# ============================================================================
OPENCLAW_REPOS=

# ============================================================================
# Git commit identity (for sandbox PRs)
# ============================================================================
GIT_AUTHOR_EMAIL=openclaw@bot.local
GIT_AUTHOR_NAME=OpenClaw Bot

# ============================================================================
# Gmail (optional — OAuth2 credentials for email access)
# ============================================================================
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...
GMAIL_USER_EMAIL=you@gmail.com

# ============================================================================
# GCP (for GCS backup + Compute Engine)
# ============================================================================
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ============================================================================
# GCE Deployment (used by deploy-gce.sh and setup.sh)
# ============================================================================
# VM instance name (lowercase, hyphens ok, no spaces)
OPENCLAW_INSTANCE=openclaw-vm
# Machine type (default: e2-medium)
OPENCLAW_MACHINE_TYPE=e2-medium
# Zone override (default: {GCP_REGION}-a)
# GCP_ZONE=us-central1-a

# Alternative credential injection (optional):
# GCP_SA_KEY_B64=base64-of-service-account-json
